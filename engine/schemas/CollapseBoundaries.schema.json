{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CollapseBoundaries",
  "type": "object",
  "properties": {
    "field": { "type": "string", "const": "collapse-boundaries" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "units": { "type": "string" },
    "boundaries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "shape": { "type": "string" },
          "points": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" }
              },
              "required": ["x", "y"]
            }
          }
        },
        "required": ["shape", "points"]
      }
    },
    "metadata": { "type": "object" }
  },
  "required": ["field", "version", "boundaries"]
}
