{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RestorationFlows",
  "type": "object",
  "properties": {
    "field": { "type": "string", "const": "restoration-flows" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "units": { "type": "string" },
    "flows": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            },
            "required": ["x", "y"]
          },
          "to": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            },
            "required": ["x", "y"]
          },
          "cost": { "type": "number" }
        },
        "required": ["from", "to", "cost"]
      }
    },
    "metadata": { "type": "object" }
  },
  "required": ["field", "version", "flows"]
}
